# Only files that are specific to my setup are listed here.
# The rest should live in project-specific .gitignore files.
.DS_Store
Desktop.ini

# Thumbnail cache files
._*
Thumbs.db

# Files that might appear on external disks
.Spotlight-V100
.Trashes

.idea

# Compiled Neovim spell files
*.spl

node_modules

.beads
.gitattributes

# Karabiner writes throwaway restore-points and cached assets into its config
# dir, which is symlinked into the repo; track karabiner.json, ignore the rest
.config/karabiner/automatic_backups/
.config/karabiner/assets/

**/.claude/settings.local.json

            "type": "command",
            "command": "/Users/carosi/.local/bin/squawk hook"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/carosi/.local/bin/squawk hook",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {

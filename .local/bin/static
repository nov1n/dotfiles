#!/usr/bin/env bash

# Script to upload a file via SCP and copy the URL to the clipboard.
# Pass --private (or -p) to upload into the password-protected /private area.

REMOTE_HOST="homelab"
REMOTE_BASE="/home/carosi/static"
DOMAIN="static.carosi.nl"
SSH_PORT="${SSH_PORT:-22}" # Override with the SSH_PORT env var if needed

# Parse optional --private / -p flag (must come before the filename).
URL_PREFIX=""
REMOTE_SUBDIR=""
if [ "$1" = "--private" ] || [ "$1" = "-p" ]; then
  REMOTE_SUBDIR="/private"
  URL_PREFIX="private/"
  shift
fi

LOCAL_FILE="$1"
REMOTE_PATH="${REMOTE_BASE}${REMOTE_SUBDIR}"

upload_file() {
  # Check if the local file exists
  if [ ! -f "$LOCAL_FILE" ]; then
    echo "Error: Local file not found: $LOCAL_FILE"
    return 1
  fi

  # Extract the filename from the local path
  FILENAME=$(basename "$LOCAL_FILE")

  # Ensure the remote directory exists (the /private subdir may not yet).
  if ! ssh -p "$SSH_PORT" "$REMOTE_HOST" "mkdir -p \"$REMOTE_PATH\""; then
    echo "Error: could not create remote directory $REMOTE_PATH"
    return 1
  fi

  # Upload the file
  echo "Uploading file..."
  if ! scp -P "$SSH_PORT" "$LOCAL_FILE" "$REMOTE_HOST:$REMOTE_PATH/"; then
    echo "Error: SCP failed. Check your connection, credentials, and paths."
    return 1
  fi

  # URL encode the filename for special characters
  ENCODED_FILENAME=$(printf %s "$FILENAME" | jq -sRr @uri)

  # Construct the URL
  URL="https://${DOMAIN}/${URL_PREFIX}${ENCODED_FILENAME}"

  # Copy the URL to the clipboard
  echo "Copying URL to clipboard..."
  if echo "$URL" | cb; then
    echo "URL copied to clipboard: $URL"
  else
    echo "Warning: Could not copy to clipboard."
    echo "URL: $URL"
  fi

  return 0
}

# --- Main Script ---

if [ -z "$LOCAL_FILE" ]; then
  echo "Usage: $0 [--private|-p] <local_file>"
  echo "Example: $0 my_image.jpg"
  echo "         $0 --private secret.pdf"
  exit 1
fi

upload_file
exit $? # Exit with the return code of the upload_file function

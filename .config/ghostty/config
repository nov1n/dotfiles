# ╭─────────────────────────────────────────────────────────╮
# │                         System                          │
# ╰─────────────────────────────────────────────────────────╯

shell-integration-features = cursor,sudo,title

mouse-hide-while-typing = true
# Default multiplier is 3 (~15 lines/tick); 1 slows it to ~5.
mouse-scroll-multiplier = 1
resize-overlay = never
confirm-close-surface = false
# Don't restore window state. Required for the quick terminal: Ghostty only sets
# GHOSTTY_QUICK_TERMINAL on a freshly created surface (surfaceTree empty), so a
# restored surface would never get the var. Trade-off: regular windows also
# won't be restored (tmux handles persistence anyway).
window-save-state = never

# No `command` override on purpose: overriding it drops GHOSTTY_QUICK_TERMINAL,
# which Ghostty only sets on its default shell launch. The tmux hand-off (quick
# terminal -> "quick", regular windows -> most recent session other than
# "quick") lives at the top of ~/.zshrc instead, where that env var is set.

# Send Option as Alt so tmux/nvim receive M-h/j/k/l etc. instead of macOS
# compose characters (˙∆˚¬). Required for smart-splits.nvim + tmux pane nav.
macos-option-as-alt = true

# ╭─────────────────────────────────────────────────────────╮
# │                       Appearance                        │
# ╰─────────────────────────────────────────────────────────╯

# Theme - using Tokyo Night
theme = tokyonight

# Font configuration
font-family = JetBrainsMono Nerd Font Mono
font-size = 18

# Window
macos-titlebar-proxy-icon = hidden
macos-titlebar-style = tabs
title = " "
window-padding-balance = true
macos-icon = glass
macos-icon = custom-style
macos-icon-frame = aluminum
macos-icon-ghost-color = #ffffff
macos-icon-screen-color = #000000

# ╭─────────────────────────────────────────────────────────╮
# │                         Keymap                          │
# ╰─────────────────────────────────────────────────────────╯

# Note: Ghostty doesn't support disabling all default keybindings,
# but we can remap the ones we want

# Splits and tabs disabled — tmux handles multiplexing instead.
# Unbind all Ghostty default split/tab keymaps so they don't shadow tmux/nvim.

# Splits
keybind = super+[=unbind
keybind = super+]=unbind
keybind = super+ctrl+==unbind
keybind = super+ctrl+arrow_up=unbind
keybind = super+ctrl+arrow_down=unbind
keybind = super+ctrl+arrow_left=unbind
keybind = super+ctrl+arrow_right=unbind
keybind = super+d=unbind
keybind = super+shift+d=unbind

# Windows
keybind = super+n=unbind

# Tabs
keybind = super+t=unbind
keybind = super+w=unbind
keybind = super+alt+w=unbind
keybind = super+shift+[=unbind
keybind = super+shift+]=unbind
keybind = super+digit_1=unbind
keybind = super+digit_2=unbind
keybind = super+digit_3=unbind
keybind = super+digit_4=unbind
keybind = super+digit_5=unbind
keybind = super+digit_6=unbind
keybind = super+digit_7=unbind
keybind = super+digit_8=unbind
keybind = super+digit_9=unbind

# Map control backspace to Control-w
keybind = ctrl+backspace=text:\x17

# Shift+Enter sends ESC+CR (for Claude Code multi-line input)
keybind = shift+enter=text:\x1b\r

# Cmd+K triggers sesh (tmux session picker): sends prefix (C-a) + s.
# Overrides Ghostty's default clear-scrollback on cmd+k.
keybind = super+k=text:\x01s

# Quick terminal
keybind = global:super+ctrl+alt+shift+t=toggle_quick_terminal
quick-terminal-position = top
quick-terminal-size = 60%,2841px
quick-terminal-animation-duration = 0


# ╭─────────────────────────────────────────────────────────╮
# │                         System                          │
# ╰─────────────────────────────────────────────────────────╯

shell-integration-features = cursor,sudo,title

# Auto-attach to (or create) a tmux session named "main" on launch.
# Route through a login zsh so .zprofile runs first — otherwise tmux inherits
# a bare PATH (no /opt/homebrew/bin) and plugin scripts using `env bash` fall
# back to macOS's bash 3.2, breaking tokyo-night-tmux and friends.
command = /opt/homebrew/bin/zsh -lc 'exec tmux new-session -A -s main'

# Send Option as Alt so tmux/nvim receive M-h/j/k/l etc. instead of macOS
# compose characters (˙∆˚¬). Required for smart-splits.nvim + tmux pane nav.
macos-option-as-alt = true

# ╭─────────────────────────────────────────────────────────╮
# │                       Appearance                        │
# ╰─────────────────────────────────────────────────────────╯

# Theme - using Tokyo Night
theme = tokyonight

# Font configuration
font-family = JetBrainsMono Nerd Font Mono
font-size = 18

# ╭─────────────────────────────────────────────────────────╮
# │                         Keymap                          │
# ╰─────────────────────────────────────────────────────────╯

# Note: Ghostty doesn't support disabling all default keybindings,
# but we can remap the ones we want

# Splits and tabs disabled — tmux handles multiplexing instead.
# Unbind all Ghostty default split/tab keymaps so they don't shadow tmux/nvim.

# Splits
keybind = super+[=unbind
keybind = super+]=unbind
keybind = super+ctrl+==unbind
keybind = super+ctrl+arrow_up=unbind
keybind = super+ctrl+arrow_down=unbind
keybind = super+ctrl+arrow_left=unbind
keybind = super+ctrl+arrow_right=unbind
keybind = super+d=unbind
keybind = super+shift+d=unbind

# Windows
keybind = super+n=unbind

# Tabs
keybind = super+t=unbind
keybind = super+w=unbind
keybind = super+alt+w=unbind
keybind = super+shift+[=unbind
keybind = super+shift+]=unbind
keybind = super+digit_1=unbind
keybind = super+digit_2=unbind
keybind = super+digit_3=unbind
keybind = super+digit_4=unbind
keybind = super+digit_5=unbind
keybind = super+digit_6=unbind
keybind = super+digit_7=unbind
keybind = super+digit_8=unbind
keybind = super+digit_9=unbind


# Font size
keybind = super+minus=decrease_font_size:1
keybind = super+equal=increase_font_size:1
keybind = super+0=reset_font_size

# Map control backspace to Control-w
keybind = ctrl+backspace=text:\x17

# Shift+Enter sends ESC+CR (for Claude Code multi-line input)
keybind = shift+enter=text:\x1b\r

# Scrolling
keybind = shift+up=scroll_page_fractional:-0.1
keybind = shift+down=scroll_page_fractional:0.1
keybind = page_up=scroll_page_fractional:-0.5
keybind = page_down=scroll_page_fractional:0.5
